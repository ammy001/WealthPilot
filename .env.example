# ---- LLM provider switch --------------------------------------------------
# Which chat LLM to use: ollama | groq | custom
LLM_PROVIDER=ollama

# ollama (OpenAI-compatible endpoint; CloudXP or local)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_API_KEY=ollama
OLLAMA_MODEL=llama3.3:latest

# groq (OpenAI-compatible)
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# custom OpenAI-based endpoint (e.g. deepseek-r1-70b on CloudXP)
CUSTOM_BASE_URL=
CUSTOM_API_KEY=
CUSTOM_MODEL=
# If your endpoint authenticates via a custom header instead of "Authorization: Bearer",
# set the header name here (e.g. apikey). Leave blank to use standard Bearer auth.
CUSTOM_API_KEY_HEADER=

# ---- Embeddings (mxbai via Ollama) ----------------------------------------
EMBED_BASE_URL=http://localhost:11434/v1
EMBED_API_KEY=ollama
EMBED_MODEL=mxbai-embed-large
EMBED_DIM=1024

# ---- Postgres / pgvector --------------------------------------------------
PG_HOST=localhost
PG_PORT=5432
PG_DB=wealthpilot
PG_USER=postgres
PG_PASSWORD=
