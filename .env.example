# ---- LLM provider switch --------------------------------------------------
# Which chat LLM to use: ollama | groq | custom | azure
LLM_PROVIDER=ollama

# azure (Azure OpenAI; `model` = the deployment name, not the base model id)
OPENAI_API_VERSION=2024-08-01-preview
AZURE_OPENAI_ENDPOINT=
DEPLOYMENT_NAME=
OPENAI_AIML_KEY=

# ollama (OpenAI-compatible endpoint; CloudXP or local)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_API_KEY=ollama
OLLAMA_MODEL=llama3.3:latest

# groq (OpenAI-compatible; very fast hosted inference — get a free key at console.groq.com)
# NB: llama-3.1-8b-instant is deprecated for free/dev tier (2026-06-17) -> openai/gpt-oss-20b.
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# custom OpenAI-based endpoint (e.g. deepseek-r1-70b on CloudXP)
CUSTOM_BASE_URL=
CUSTOM_API_KEY=
CUSTOM_MODEL=
# If your endpoint authenticates via a custom header instead of "Authorization: Bearer",
# set the header name here (e.g. apikey). Leave blank to use standard Bearer auth.
CUSTOM_API_KEY_HEADER=

# ---- Embeddings ------------------------------------------------------------
# Ollama-native style: POST {EMBED_BASE_URL}{EMBED_PATH} {"model","prompt"} -> {"embedding"}
# For standard Ollama use EMBED_PATH=/api/embeddings; CloudXP uses /api/cloudxp/embeddings.
# EMBED_DIM MUST match the model's output dim (mxbai-embed-large=1024, nomic-embed-text=768).
# Changing the model/dim requires re-running `python -m rag.ingest` (vectors are re-embedded).
EMBED_BASE_URL=http://localhost:11434
EMBED_PATH=/api/embeddings
EMBED_MODEL=mxbai-embed-large
EMBED_DIM=1024
EMBED_API_KEY=
# Light Colab alternative:  EMBED_MODEL=nomic-embed-text  EMBED_DIM=768

# ---- Reranker (cross-encoder via sentence-transformers) --------------------
# Default is BAAI/bge-reranker-v2-m3 (0-1 scores). Light alternative for Colab:
#   RERANKER_MODEL=mixedbread-ai/mxbai-rerank-xsmall-v1
# NOTE: score scale can differ per model — if you switch, sanity-check the top
# score (python -m rag.retrieve "a query") and retune RAG_CONF_THRESHOLD/RAG_KEEP_SCORE.
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# ---- Postgres / pgvector --------------------------------------------------
# Either set PG_DSN (preferred) or the PG_* parts. PG_SCHEMA sets search_path.
PG_DSN=
PG_SCHEMA=public
PG_HOST=localhost
PG_PORT=5432
PG_DB=wealthpilot
PG_USER=postgres
PG_PASSWORD=
